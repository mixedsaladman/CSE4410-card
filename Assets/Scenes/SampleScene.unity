      m_Calls: []
  m_text: ": \tSubtracts from health, {lose} upon reaching 0.\n\tJ = 11, Q = 12,
    K = 13, A = 14\n\tMust slay 26 to {win}.\n\n: \tRestores missing health.\n\tCan
    only heal once per round.\n\n\n:\tReduces damage taken.\n\tReplaced by the most
    recent diamond.\n\tOnce used, can only reduce the damage for those of lesser
    \n\tstrength than the card it was last used against, breaks otherwise.\n\n\n\n:\tOnly
    interacts with the first 3 cards, Left -> Right.\n\n\n\n:\tDoesn't interact with
    any cards, and draws new ones.\n\tCannot avoid twice in a row.\n\tAvoided cards
    reappear near the end."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
